// --- Proteção para o Popup de Pastas ---
const openFolderPopupBtn = document.getElementById("openFolderPopup");
const closeFolderBtn = document.getElementById("closeFolder");
const folderPopup = document.getElementById("folderPopup");

if (openFolderPopupBtn && folderPopup) {
    openFolderPopupBtn.addEventListener("click", () => {
        folderPopup.classList.remove("hide");
    });
}

if (closeFolderBtn && folderPopup) {
    closeFolderBtn.addEventListener("click", () => {
        folderPopup.classList.add("hide");
    });
}

// --- Proteção para o Popup de Flashcards ---
const closeFlashcardsBtn = document.getElementById("closeFlashcards");
const flashcardPopup = document.getElementById("flashcardPopup");

if (closeFlashcardsBtn && flashcardPopup) {
    closeFlashcardsBtn.addEventListener("click", () => {
        flashcardPopup.classList.add("hide");
    });
}

// --- Função para Salvar Flashcard (Verificando se os inputs existem) ---
async function salvarFlashcard() {
    const questionInput = document.getElementById("question");
    const answerInput = document.getElementById("answer");

    // Só avança se os inputs existirem na tela atual
    if (!questionInput || !answerInput) return;

    const pergunta = questionInput.value;
    const resposta = answerInput.value;

    const usuario = JSON.parse(localStorage.getItem("usuario"));

    if (!usuario) {
        alert("Você precisa estar logado!");
        return;
    }

    try {
        const respostaServidor = await fetch("/flashcards", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                pergunta,
                resposta,
                usuarioId: usuario.id
            })
        });

        const data = await respostaServidor.json();
        alert(data.msg);

    } catch (erro) {
        console.log(erro);
        alert("Erro ao salvar flashcard");
    }
}

// --- Evento do Botão Salvar Flashcard (Protegido) ---
const saveCardBtn = document.getElementById("saveCard");
if (saveCardBtn) {
    saveCardBtn.addEventListener("click", salvarFlashcard);
}