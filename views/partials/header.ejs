<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>
        <%= title %>
    </title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/semantic-ui/2.4.1/semantic.min.css">
    <link rel="stylesheet" href="/stylesheets/index.css">

    <style>
        body {
            background: #f5f7fb;
        }
        
        .ui.menu {
            background: linear-gradient(135deg, #54aaff, #54aaff) !important;
            border: none !important;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
            padding: 5px;
            border-radius: 0 !important;
        }
        
        .nav-logo {
            height: 45px !important;
            /* Aumentado de 35px para 45px */
            width: auto !important;
            object-fit: contain;
        }
        
        .nav-logo-direita {
            height: 50px !important;
            width: auto !important;
            object-fit: contain;
            margin-right: 10px;
            display: block !important;
        }
        /* Ajuste extra: Remove o limite que o Semantic UI coloca que espreme os itens */
        
        .ui.menu .item img {
            max-height: none !important;
        }
        
        .ui.menu .item {
            color: white !important;
            background: transparent !important;
            font-weight: bold;
            border-radius: 0 !important;
            transition: 0.2s ease;
            text-decoration: none !important;
            display: flex;
            align-items: center;
        }
        
        .ui.menu .item:hover,
        .ui.menu .item:focus,
        .ui.menu .item:active {
            background: rgba(255, 255, 255, 0.15) !important;
            color: white !important;
            transform: translateY(-1px);
        }
        
        .ui.menu .active.item {
            background: transparent !important;
            color: white !important;
        }
        
        .ui.menu a {
            text-decoration: none !important;
        }
        
        .ui.menu {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
        }
        
        .ui.inverted.footer {
            background: linear-gradient(135deg, #54aaff, #54aaff);
            color: white;
            box-shadow: 0 -6px 20px rgba(0, 0, 0, 0.15);
            padding: 15px;
            text-align: center;
            font-weight: bold;
        }
        
        .ui.inverted.footer {
            border-radius: 0 !important;
            box-shadow: none !important;
        }
        
        .ui.inverted.footer {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
        }
    </style>
</head>

<body>
    <header>
        <div class="ui inverted menu">
            <a class="item" href="/">
                <img class="nav-logo" src="/images/pastafixly.png" alt="Fixly Logo">
            </a>

            <a class="item" href="/">Início</a>
            <a class="item" href="/about">Sobre</a>
            <a class="item" href="/signup">Inscreva-se</a>
            <a class="item" href="/login">Entrar</a>
            <a class="item" href="/flashcards">Criar Flashcards</a>
            <a class="item" href="/profile">Meu Perfil</a>

            <div class="right menu">
                <div class="item" style="padding-dash: 0; padding-right: 0;">
                    <img class="nav-logo-direita" src="/images/fixlyseta.png" alt="Ícone Direita">
                </div>

                <a class="item" href="/auth/logout" style="color: #ff6b6b; font-weight: bold;" onclick="fazerLogout(event)">Sair</a>
            </div>
        </div>
    </header>

    <main class="main-content">

        <script>
            // Função executada ao clicar em "Sair" para limpar dados residuais do front-end
            function fazerLogout(event) {
                // Limpa o localStorage para não deixar rastro do usuário antigo na tela
                localStorage.removeItem("usuario");
                localStorage.removeItem("usuarioId");

                // Deixa o link seguir o caminho natural para o servidor (/auth/logout) limpar o cookie de sessão
            }
        </script>