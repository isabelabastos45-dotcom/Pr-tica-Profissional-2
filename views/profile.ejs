<%- include('partials/header', { title: 'Meu Perfil' }) %>

<style>
  body {
    background: linear-gradient(180deg, #74b9ff 0%, #dfefff 60%, #ffffff 100%);
    background-attachment: fixed;
    min-height: 100vh;
    margin: 0;
    padding: 0;
    font-family: sans-serif;
  }

  .perfil-container {
    background: rgba(255, 255, 255, 0.9);
    max-width: 550px;
    margin: 60px auto 100px auto;
    padding: 40px;
    border-radius: 25px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    text-align: center;
    box-sizing: border-box;
  }

  .perfil-container h1 {
    font-family: 'Merriweather', serif;
    color: #104488;
    font-size: 32px;
    margin-top: 0;
    margin-bottom: 20px;
  }

  /* --- Círculo da Foto de Perfil --- */
  .avatar-container {
    margin-bottom: 15px;
    position: relative;
    display: inline-block;
  }

  .avatar-preview {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid #74b9ff;
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    background-color: #e3f2fd;
  }

  /* --- Estilização do Botão de Escolher Arquivo --- */
  .foto-form {
    margin-bottom: 30px;
  }

  /* Esconde o input feio padrão do sistema */
  #input-file-foto {
    display: none;
  }

  /* Cria um botão bonito combinando com o Fixly */
  .label-upload {
    display: inline-block;
    background: #104488;
    color: white;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: bold;
    font-size: 14px;
    transition: background 0.2s, transform 0.1s;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  }

  .label-upload:hover {
    background: #002d66;
  }

  .label-upload:active {
    transform: scale(0.98);
  }

  /* --- Caixas de Informação --- */
  .info-box {
    background: #ffffff;
    padding: 15px 20px;
    border: 1px solid #dfefff;
    border-radius: 12px;
    margin-bottom: 15px;
    text-align: left;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .info-box p {
    margin: 0;
    font-size: 16px;
    color: #333;
  }

  .info-box strong {
    color: #104488;
  }

  .btn-voltar {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 30px;
    border: none;
    border-radius: 8px;
    background-color: #007bff;
    color: white;
    font-size: 16px;
    font-weight: bold;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-voltar:hover {
    background-color: #0056b3;
  }
</style>

<div class="perfil-container">
  <h1>Meu Perfil</h1>
  
  <div class="avatar-container">
    <img id="perfil-foto-img" class="avatar-preview" src="https://cdn-icons-png.flaticon.com/512/149/149071.png" alt="Foto de Perfil">
  </div>

  <div class="foto-form">
    <input type="file" id="input-file-foto" accept="image/*" onchange="atualizarFotoLocal(this)">
    <label for="input-file-foto" class="label-upload">Escolher Foto</label>
  </div>
  
  <div class="info-box">
    <p><strong>Nome:</strong> <span id="perfil-nome">Carregando...</span></p>
  </div>
  
  <div class="info-box">
    <p><strong>Usuário:</strong> <span id="perfil-username">Carregando...</span></p>
  </div>
  
  <div class="info-box">
    <p><strong>E-mail:</strong> <span id="perfil-email">Carregando...</span></p>
  </div>

  <a href="/" class="btn-voltar">Voltar ao Início</a>
</div>

<script>
  // Função que carrega o perfil ao abrir a tela
  function carregarPerfil() {
      const usuario = JSON.parse(localStorage.getItem("usuario"));
      
      if (!usuario) {
          alert("Você precisa estar logado para ver seu perfil!");
          window.location.href = "/login";
          return;
      }
      
      document.getElementById('perfil-nome').innerText = usuario.nome || "Não informado";
      document.getElementById('perfil-username').innerText = usuario.username ? `@${usuario.username}` : "Não informado";
      document.getElementById('perfil-email').innerText = usuario.email || "Não informado";
      
      // Se já tiver uma imagem em Base64 salva no localStorage, exibe ela
      if (usuario.fotoUrl) {
          document.getElementById('perfil-foto-img').src = usuario.fotoUrl;
      }
  }

  // Função mágica que pega o arquivo do PC/Celular e transforma em texto para salvar
  function atualizarFotoLocal(input) {
      if (input.files && input.files[0]) {
          const arquivo = input.files[0];

          // Validação simples de tamanho (evita travar o localStorage com imagens gigantes)
          if (arquivo.size > 2 * 1024 * 1024) { 
              alert("Escolha uma imagem de até 2MB para não sobrecarregar o sistema!");
              return;
          }

          const leitor = new FileReader();
          
          // Quando terminar de ler o arquivo...
          leitor.onload = function(e) {
              const base64String = e.target.result; // Imagem convertida em texto seguro
              
              const usuario = JSON.parse(localStorage.getItem("usuario"));
              if (usuario) {
                  // Grava a string da imagem no objeto do usuário
                  usuario.fotoUrl = base64String;
                  localStorage.setItem("usuario", JSON.stringify(usuario));
                  
                  // Atualiza a pré-visualização na hora
                  document.getElementById('perfil-foto-img').src = base64String;
                  alert("Foto de perfil atualizada!");
              }
          }
          
          leitor.readAsDataURL(arquivo); // Dispara a conversão da imagem
      }
  }

  window.addEventListener('DOMContentLoaded', carregarPerfil);
</script>

<%- include('partials/footer') %>