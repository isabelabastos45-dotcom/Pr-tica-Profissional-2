<%- include('partials/header', { title: 'Página de usuário' }) %>

<h2>Página de usuário</h2>

<%- include('partials/footer') %>
<style>
.profile-container{
    max-width: 500px;
    margin: 50px auto;
    padding: 30px;
    border-radius: 15px;
    background: #f5f5f5;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
    text-align: center;
}

.profile-avatar{
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: #ccc;
    margin: 0 auto 20px;
}

.profile-info{
    margin: 15px 0;
    font-size: 18px;
}
</style>

<div class="profile-container">

    <div class="profile-avatar"></div>

    <h1 id="nome"></h1>

    <div class="profile-info">
        <strong>Username:</strong>
        <span id="username"></span>
    </div>

    <div class="profile-info">
        <strong>Email:</strong>
        <span id="email"></span>
    </div>

    <button onclick="logout()">
        Sair da conta
    </button>

</div>

<script>

const usuario = JSON.parse(
    localStorage.getItem("usuario")
);

if(!usuario){
    window.location.href = "/login";
}

document.getElementById("nome").innerText =
    usuario.nome;

document.getElementById("email").innerText =
    usuario.email;

document.getElementById("username").innerText =
    usuario.username || "Sem username";


function logout(){

    localStorage.clear();

    window.location.href = "/login";
}

</script>

<%- include('partials/footer') %>